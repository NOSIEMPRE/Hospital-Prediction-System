# ── Git / OS ──────────────────────────────────────────────
.git
.github
.gitignore
.flake8
.vscode
.idea
*.DS_Store

# ── Python cache ──────────────────────────────────────────
__pycache__
*.pyc
.pytest_cache
.mypy_cache
*.egg-info/

# ── Virtual environments ─────────────────────────────────
.venv
venv
.pylibs

# ── MLflow local state (Do not bake dev tracking DB into prod image)
mlflow.db
mlruns/
mlartifacts/

# ── Local models (CI/CD artifact flow creates models during build)
# We ONLY want what's in models/, anything else is local experimentation
artifacts/

# ── Notebooks & docs (not needed in prod image) ──────────
01-initial-notebook/
02-data-sampling-feature/
03-experiment-tracking/
04-deployment/
05-monitoring/
docs/
*.ipynb
*.pdf
*.md
*.docx

# ── Data (Exclude entire data dir so dev datasets don't bloat the image)
data/

# ── Misc ──────────────────────────────────────────────────
.env
render.yaml
pyproject.toml
